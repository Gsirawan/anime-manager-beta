# AniDB UDP API credentials
# Register a client at: https://anidb.net/software/add
ANIDB_USER=
ANIDB_PASS=
ANIDB_CLIENT=animemanager
ANIDB_CLIENTVER=1

# AniDB HTTP API client — REGISTERED SEPARATELY from UDP at the same URL.
# Used for fetching anime metadata (no AUTH, no session, no source-port pin).
# A client must be added with type "HTTP API" — it can share a base name
# with your UDP client but must be its own registration.
ANIDB_HTTP_CLIENT=animemanager
ANIDB_HTTP_CLIENTVER=1

# AniDB UDP server — per AniDB docs these must not be hardcoded
ANIDB_SERVER=api.anidb.net
ANIDB_PORT=9000

# Optional: AES128 encrypted UDP (recommended once stable)
# Get API key from your AniDB profile settings
ANIDB_API_KEY=

# Local UDP source port for AniDB packets. MUST be fixed and reused across
# restarts. AniDB bans IPs that send from many different source ports within
# an hour (looks like NAT abuse to them). Pick anything >1024 that's free on
# this host and keep it forever.
ANIDB_LOCAL_PORT=9001

# Server
# NOTE: mini PC has another app on 3000 — use 3001 there.
PORT=3001
HOST=0.0.0.0
DATABASE_PATH=./data/anime.db

# Logging
LOG_LEVEL=info
